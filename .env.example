# =============================================================================
# Sprintable — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Usage: cp .env.example .env && docker compose up -d

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

POSTGRES_DB=sprintable
POSTGRES_USER=sprintable
POSTGRES_PASSWORD=change-me-in-production

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------

# Constructed automatically by docker-compose from the above values.
# Override here only if running backend outside docker-compose.
# DATABASE_URL=postgresql://sprintable:change-me@localhost:5432/sprintable

# JWT signing secret — minimum 32 characters, generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production-min-32-chars

# Internal secret key used for misc crypto operations
SECRET_KEY=change-me-in-production-min-32-chars

# Backend port (default: 8000)
# BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------

# Public URL of this deployment (used in links, webhooks, OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL where the backend is reachable from the browser (in docker-compose: http://backend:8000)
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# Frontend port (default: 3000)
# PORT=3000

# -----------------------------------------------------------------------------
# AI (optional — required for AI features)
# -----------------------------------------------------------------------------

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# GitHub Webhook (optional — auto-close tickets when PRs merge)
# -----------------------------------------------------------------------------

# Secret token shared with GitHub webhook. Generate: openssl rand -hex 32
# GITHUB_WEBHOOK_SECRET=
