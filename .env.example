# =============================================================================
# Sprintable — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Usage: cp .env.example .env && docker compose up -d

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

POSTGRES_DB=sprintable
POSTGRES_USER=sprintable
POSTGRES_PASSWORD=change-me-in-production

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------

# Constructed automatically by docker-compose from the above values.
# Override here only if running backend outside docker-compose.
# DATABASE_URL=postgresql://sprintable:change-me@localhost:5432/sprintable

# JWT signing secret — minimum 32 characters, generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production-min-32-chars

# Internal secret key used for misc crypto operations
SECRET_KEY=change-me-in-production-min-32-chars

# Backend port (default: 8000)
# BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------

# 이 배포의 공개 URL — webhook payload 등에 사용·docker-compose가 NEXT_PUBLIC_APP_URL에도 주입
APP_BASE_URL=http://localhost:3108

# Public URL of this deployment (used in links, webhooks, OAuth redirects)
# docker-compose default port is 3108
NEXT_PUBLIC_APP_URL=http://localhost:3108

# URL where the backend is reachable from the browser
# docker-compose: auto-configured as http://backend:8000 via build args — do not override
# standalone (non-docker): set to http://localhost:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# Frontend port (default: 3108)
# PORT=3108

# -----------------------------------------------------------------------------
# AI (optional — required for AI features)
# -----------------------------------------------------------------------------

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# GitHub Webhook (optional — auto-close tickets when PRs merge)
# -----------------------------------------------------------------------------

# Secret token shared with GitHub webhook. Generate: openssl rand -hex 32
# GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Agent Chat / fakechat MCP (optional — required for real-time agent chat)
# -----------------------------------------------------------------------------
# fakechat is the MCP plugin that connects Claude Code (or any MCP agent) to
# the Sprintable real-time chat channel via WebSocket.
#
# Setup:
#   1. In Sprintable UI: Settings → Agents → New Agent → copy Agent ID + API Key
#   2. Add to your Claude Code .mcp.json (see README → Agent Chat)
#   3. Set the two variables below in your .env (or in the MCP env block)
#
# SPRINTABLE_AGENT_ID — UUID of the agent team member (from Settings → Agents)
# SPRINTABLE_AGENT_ID=00000000-0000-0000-0000-000000000000
#
# SPRINTABLE_API_KEY — API key for WS authentication (sk_live_...)
# SPRINTABLE_API_KEY=sk_live_...
#
# SPRINTABLE_WS_URL — WebSocket base URL of the backend
#   docker-compose (host → container): ws://localhost:8000  (default)
#   docker-compose (container → container): ws://backend:8000
# SPRINTABLE_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# Storage (blob/attachments) — E-STORAGE-SSOT
# -----------------------------------------------------------------------------
# Selects the blob storage backend for chat/story attachments (FE + BE).
#   local (default)  zero-config disk storage — no cloud account needed
#   gcs              Google Cloud Storage (V4 signed reads / IAM SignBlob)
#   s3 | minio       S3-compatible (presigned reads; set S3_ENDPOINT for minio)
#
# ⚠️ Existing GCS deployments MUST set STORAGE_PROVIDER=gcs explicitly.
#    Leaving it unset falls back to local disk → attachments land on ephemeral
#    storage and are lost on instance recycle (breaks existing chat/story files).
# STORAGE_PROVIDER=local

# Attachment container (GCS/S3 bucket name · local subdirectory under the root).
# GCS_MEMO_ATTACHMENTS_BUCKET=sprintable-memo-attachments

# --- local provider ---
# Object root directory. A subdirectory per container is created beneath it.
# STORAGE_LOCAL_ROOT=.storage
# HMAC secret for short-lived read URLs. MUST be shared between frontend and
# backend, and overridden in production self-host (the default is dev-only).
# STORAGE_LOCAL_SIGNING_SECRET=
# Backend-only: absolute base URL of the frontend that serves local objects.
# STORAGE_LOCAL_SERVE_BASE_URL=http://localhost:3108

# --- gcs provider ---
# GCS_PROJECT_ID=
# Optional explicit key file as JSON (otherwise Workload Identity / ADC is used).
# GCS_CREDENTIALS_JSON=

# --- s3 / minio provider ---
# S3_REGION=us-east-1
# S3_ENDPOINT=            # set for minio / S3-compatible (enables path-style)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false
