{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@sprintable/shared": ["../../packages/shared/src/index.ts"],
      "@sprintable/shared/*": ["../../packages/shared/src/*"],
      "@sprintable/core-storage": ["../../packages/core-storage/src/index.ts"],
      "@sprintable/core-storage/*": ["../../packages/core-storage/src/*"],
      "@sprintable/storage-sqlite": ["../../packages/storage-sqlite/src/index.ts"],
      "@sprintable/storage-sqlite/*": ["../../packages/storage-sqlite/src/*"],
      "@sprintable/storage-supabase": ["../../packages/storage-supabase/src/index.ts"],
      "@sprintable/storage-supabase/*": ["../../packages/storage-supabase/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "tmp-*.ts"]
}
