{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@sprintable/shared": ["../../packages/shared/src/index.ts"],
      "@sprintable/shared/*": ["../../packages/shared/src/*"],
      "@sprintable/core-storage": ["../../packages/core-storage/src/index.ts"],
      "@sprintable/core-storage/*": ["../../packages/core-storage/src/*"],
      "@sprintable/storage-api": ["../../packages/storage-api/src/index.ts"],
      "@sprintable/storage-api/*": ["../../packages/storage-api/src/*"],
      "@ee/*": ["../../ee/packages/*"],
      "@moonklabs/storage-saas": ["../../ee/packages/storage-saas/src/index.ts"],
      "@moonklabs/storage-saas/*": ["../../ee/packages/storage-saas/src/*"],
      "@moonklabs/mcp-server-saas": ["../../ee/packages/mcp-server-saas/src/index.ts"],
      "@moonklabs/mcp-server-saas/*": ["../../ee/packages/mcp-server-saas/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "tmp-*.ts", "e2e"]
}
